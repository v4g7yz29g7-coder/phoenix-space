* { margin: 0; padding: 0; box-sizing: border-box; }
body { background: #0a0a0a; font-family: 'Inter', system-ui, -apple-system, sans-serif; min-height: 100vh; display: flex; align-items: center; justify-content: center; overflow-x: hidden; color: #e0e0e0; position: relative; }
.universe-bg { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 0; background: radial-gradient(ellipse at center, #1a1a2e 0%, #0a0a0a 70%); }
.rays-container { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; pointer-events: none; display: flex; align-items: center; justify-content: center; }
.ray { position: absolute; top: 50%; left: 50%; width: 200vw; height: 2px; background: linear-gradient(90deg, transparent, rgba(255, 140, 0, 0.2), rgba(255, 100, 0, 0.5), rgba(255, 140, 0, 0.2), transparent); transform-origin: 0 50%; animation: rayPulse 3s infinite alternate ease-in-out; opacity: 0.6; }
@keyframes rayPulse { 0% { opacity: 0.4; } 100% { opacity: 0.9; } }
.main-container { position: relative; z-index: 10; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
.pulsar { width: 180px; height: 180px; margin-bottom: 2rem; position: relative; cursor: pointer; transition: transform 0.2s ease; }
.pulsar:hover { transform: scale(1.05); }
.pulsar-core { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 80px; height: 80px; background: radial-gradient(circle, #ff6b00, #ff3300); border-radius: 50%; box-shadow: 0 0 60px #ff4500, 0 0 120px #ff2200; animation: coreBeat 1.5s infinite alternate; }
@keyframes coreBeat { 0% { box-shadow: 0 0 60px #ff4500, 0 0 120px #ff2200; } 100% { box-shadow: 0 0 90px #ff5e00, 0 0 160px #ff3300; } }
.pulsar-ring { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 160px; height: 160px; border: 2px solid rgba(255, 100, 0, 0.4); border-radius: 50%; animation: ringSpin 10s linear infinite, ringGlow 2s infinite alternate; }
.pulsar-ring:nth-child(2) { width: 130px; height: 130px; animation: ringSpinReverse 8s linear infinite, ringGlow 1.5s infinite alternate; }
@keyframes ringSpin { from { transform: translate(-50%, -50%) rotate(0deg); } to { transform: translate(-50%, -50%) rotate(360deg); } }
@keyframes ringSpinReverse { from { transform: translate(-50%, -50%) rotate(0deg); } to { transform: translate(-50%, -50%) rotate(-360deg); } }
@keyframes ringGlow { 0% { border-color: rgba(255, 100, 0, 0.3); } 100% { border-color: rgba(255, 140, 0, 0.7); } }
.nav-buttons { display: flex; flex-wrap: wrap; gap: 1.2rem; justify-content: center; margin-top: 1rem; }
.nav-btn { background: rgba(20, 20, 30, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 120, 0, 0.6); color: #ffd9b3; padding: 0.8rem 2.5rem; border-radius: 50px; font-size: 1.2rem; font-weight: 500; letter-spacing: 2px; cursor: pointer; transition: all 0.3s ease; text-transform: uppercase; box-shadow: 0 0 20px rgba(255, 100, 0, 0.2); background: rgba(0,0,0,0.4); }
.nav-btn i { margin-right: 0.5rem; color: #ffb380; }
.nav-btn:hover { background: rgba(255, 80, 0, 0.25); border-color: #ff8c00; color: #fff; box-shadow: 0 0 40px rgba(255, 100, 0, 0.5); transform: translateY(-2px); }
.screen-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0, 0, 0, 0.85); backdrop-filter: blur(15px); z-index: 100; align-items: center; justify-content: center; }
.screen-overlay.active { display: flex; }
.screen-window { background: rgba(20, 20, 30, 0.9); border: 1px solid rgba(255, 120, 0, 0.5); border-radius: 24px; padding: 2.5rem 2rem; max-width: 800px; width: 90%; max-height: 85vh; overflow-y: auto !important; scroll-behavior: smooth; -ms-overflow-style: none !important; scrollbar-width: none !important; box-shadow: 0 0 70px rgba(255, 80, 0, 0.3); color: #f0e6d8; position: relative; animation: fadeSlideIn 0.4s ease; outline: none; font-family: 'Inter', sans-serif; }
.screen-window::-webkit-scrollbar { display: none !important; width: 0 !important; height: 0 !important; }
@keyframes fadeSlideIn { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
.close-btn { position: absolute; top: 1rem; right: 1.5rem; background: none; border: none; color: rgba(255,170,102,0); font-size: 2.2rem; cursor: pointer; transition: color 0.3s ease, transform 0.2s ease; line-height: 1; z-index: 10; }
.screen-window:hover .close-btn { color: #ffaa66; }
.close-btn:hover { color: #ff5500; transform: scale(1.1); }
.academy-title { font-size: 2.4rem; margin-bottom: 0.5rem; background: linear-gradient(135deg, #ffb347, #ff3d00); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; text-align: center; font-family: 'Cormorant Garamond', serif; font-weight: 500; }
.academy-subtitle { text-align: center; color: #aa8c7a; margin-bottom: 2rem; font-style: italic; }
.hall-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 1.2rem; margin-bottom: 1.5rem; }
.hall-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255, 100, 0, 0.3); border-radius: 16px; padding: 1.5rem 1rem; text-align: center; cursor: pointer; transition: all 0.3s ease; }
.hall-card:hover { background: rgba(255, 80, 0, 0.15); border-color: #ff5500; transform: translateY(-4px); box-shadow: 0 10px 25px rgba(255, 50, 0, 0.2); }
.hall-icon { font-size: 2.5rem; display: block; margin-bottom: 0.5rem; color: #ffb380; }
.hall-card h3 { color: #ffd9b3; margin-bottom: 0.3rem; font-size: 1.1rem; font-family: 'Cormorant Garamond', serif; font-weight: 500; }
.hall-card p { color: #aa8c7a; font-size: 0.85rem; }
.key-list { display: flex; flex-direction: column; gap: 1.5rem; }
.key-item { background: rgba(255,255,255,0.03); border-left: 3px solid #ff5500; padding: 1rem 1.5rem; border-radius: 0 12px 12px 0; transition: all 0.3s ease; }
.key-item:hover { background: rgba(255,255,255,0.06); border-left-color: #ffaa00; transform: translateX(4px); }
.key-item h3 { font-size: 1.4rem; color: #ffb380; margin-bottom: 0.3rem; }
.key-item p { color: #ccbbaa; line-height: 1.6; }
.practice-block { background: rgba(0,0,0,0.3); padding: 1rem; margin-top: 1rem; border-radius: 12px; font-style: italic; }
.sutra-item { padding: 0.8rem 0; border-bottom: 1px dashed rgba(255,255,255,0.1); transition: background 0.2s; }
.sutra-item:hover { background: rgba(255,255,255,0.02); }
.sutra-item:last-child { border-bottom: none; }
.subtitle-small { margin-top: 2rem; color: #aa8c7a; font-style: italic; letter-spacing: 1px; text-align: center; }
.subtitle { margin-top: 2rem; color: #aa8c7a; font-style: italic; letter-spacing: 1px; }
#plantSeedBtn { transition: all 0.3s ease; }
#plantSeedBtn:active { transform: scale(0.95); box-shadow: 0 0 30px #ff5500; }

/* ---------- Дополнительные стили для Школы Жизни, P2P, флагов ---------- */
.school-tab { background: transparent; border: 1px solid var(--accent-main); color: var(--accent-main); padding: 0.6rem 1.8rem; border-radius: 30px; cursor: pointer; font-size: 0.95rem; transition: all 0.3s ease; }
.school-tab.active { background: var(--accent-main); color: #fff; box-shadow: 0 0 15px rgba(255,100,0,0.3); }
.school-panel { display: none; animation: fadeSlideIn 0.4s ease; }
.school-panel.active { display: block; }
.friend-card { background: rgba(20, 20, 30, 0.6); backdrop-filter: blur(10px); border: 1px solid rgba(255, 100, 0, 0.2); border-radius: 16px; padding: 1.2rem; text-align: center; cursor: pointer; transition: all 0.3s ease; }
.friend-card:hover { transform: translateY(-3px); border-color: var(--accent-main); box-shadow: 0 10px 25px rgba(255, 50, 0, 0.15); }
.goal-row { transition: all 0.2s ease; }
.goal-row:hover { background: rgba(255,255,255,0.06); }
#startCallBtn, #hangupCallBtn, #sendFileBtn { background: var(--accent-main); border: none; color: #fff; padding: 0.4rem 0.8rem; border-radius: 20px; cursor: pointer; font-size: 0.8rem; }
#hangupCallBtn, #sendFileBtn { background: transparent; border: 1px solid var(--accent-main); color: var(--accent-main); }
#startCallBtn:hover, #hangupCallBtn:hover, #sendFileBtn:hover { box-shadow: 0 0 15px rgba(255,80,0,0.5); }
#reportUserBtn { background: transparent; border: 1px solid var(--accent-main); color: var(--accent-main); padding: 0.4rem; border-radius: 20px; cursor: pointer; font-size: 0.8rem; margin-left: 0.3rem; transition: all 0.2s; }
#reportUserBtn:hover { background: rgba(255,80,0,0.2); transform: scale(1.1); }
.lang-switcher { position: fixed; top: 20px; right: 20px; z-index: 200; display: flex; flex-direction: column; align-items: flex-end; gap: 0.3rem; }
.lang-btn-current { background: rgba(20, 20, 30, 0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255, 120, 0, 0.6); color: #ffd9b3; padding: 0.5rem 1.2rem; border-radius: 30px; font-size: 0.9rem; cursor: pointer; transition: all 0.3s ease; display: flex; align-items: center; gap: 0.3rem; box-shadow: 0 0 15px rgba(0,0,0,0.5); }
.lang-btn-current:hover { background: rgba(255, 80, 0, 0.25); border-color: #ff8c00; box-shadow: 0 0 25px rgba(255,100,0,0.5); }
.lang-dropdown { display: none; flex-direction: column; background: rgba(10, 10, 20, 0.95); backdrop-filter: blur(15px); border: 1px solid rgba(255, 100, 0, 0.4); border-radius: 12px; padding: 0.4rem; min-width: 160px; box-shadow: 0 10px 25px rgba(0,0,0,0.6); }
.lang-dropdown.active { display: flex; }
.lang-option { background: transparent; border: none; color: #ccbbaa; padding: 0.6rem 0.8rem; text-align: left; font-size: 0.9rem; cursor: pointer; border-radius: 8px; transition: all 0.2s ease; display: flex; align-items: center; gap: 0.4rem; }
.lang-option:hover { background: rgba(255, 80, 0, 0.2); color: #fff; }
.lang-option.active { background: rgba(255, 80, 0, 0.3); color: #ffb380; font-weight: 500; }

/* Профиль */
.profile-container { max-width: 700px; margin: 0 auto; padding: 2rem; }
.profile-header { display: flex; gap: 1.5rem; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; justify-content: center; text-align: center; }
.avatar { width: 100px; height: 100px; border-radius: 50%; border: 2px solid var(--accent-main); object-fit: cover; background: #2a2a3e; box-shadow: 0 0 30px rgba(255, 100, 0, 0.3); }
.profile-name { font-size: 2rem; color: #ffd9b3; font-family: 'Cormorant Garamond', serif; }
.profile-did { font-size: 0.8rem; color: #aa8c7a; word-break: break-all; }
.stats { display: flex; gap: 2rem; justify-content: center; margin: 1.5rem 0; flex-wrap: wrap; }
.stat-item { text-align: center; background: rgba(255,255,255,0.03); padding: 1rem 1.5rem; border-radius: 16px; border: 1px solid rgba(255,100,0,0.2); backdrop-filter: blur(10px); min-width: 100px; }
.stat-value { font-size: 1.5rem; font-weight: 500; color: var(--accent-soft); }
.stat-label { font-size: 0.7rem; color: #aa8c7a; text-transform: uppercase; letter-spacing: 1px; }
.edit-btn { background: var(--accent-main); border: none; color: #fff; padding: 0.6rem 2rem; border-radius: 30px; cursor: pointer; font-size: 0.9rem; transition: all 0.3s ease; box-shadow: 0 0 15px rgba(255,100,0,0.3); }
.edit-btn:hover { transform: translateY(-2px); box-shadow: 0 0 30px rgba(255,100,0,0.5); }
.edit-form { display: none; margin-top: 1.5rem; background: rgba(20, 20, 30, 0.7); backdrop-filter: blur(15px); border: 1px solid rgba(255,100,0,0.4); border-radius: 20px; padding: 1.5rem; animation: fadeSlideIn 0.3s ease; }
.edit-form input[type="text"], .edit-form input[type="file"] { width: 100%; background: rgba(0,0,0,0.4); border: 1px solid rgba(255,140,0,0.3); border-radius: 12px; padding: 0.7rem; color: #fff; margin-bottom: 0.8rem; font-family: inherit; }
.edit-form button { background: var(--accent-main); border: none; color: #fff; padding: 0.6rem 2rem; border-radius: 30px; cursor: pointer; font-size: 0.9rem; transition: all 0.3s ease; }

@media (max-width: 600px) {
  .pulsar { width: 140px; height: 140px; }
  .nav-btn { padding: 0.6rem 1.5rem; font-size: 1rem; }
  .screen-window { padding: 1.5rem; }
}
